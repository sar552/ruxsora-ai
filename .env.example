# ===== ERPNext + Claude Telegram bot sozlamalari =====
# Qiymatlar Python sintaksisida: matn "tirnoq" ichida, ro'yxat [..] ko'rinishida.

# --- ERPNext ---
ERP_URL = "https://erp.example.com"
ERP_KEY = "erp_api_key"
ERP_SECRET = "erp_api_secret"

# --- Claude / Anthropic ---
ANTHROPIC_KEY = "sk-ant-..."
# Asosiy (arzon) model — oddiy savollar shu modelga ketadi:
MODEL = "claude-haiku-4-5-20251001"
# Tahlil/CFO/izoh savollari uchun KUCHLIROQ model (ixtiyoriy).
# Bo'sh qoldirsangiz hamma narsa MODEL'ga ketadi (routing o'chiq).
MODEL_SMART = "claude-sonnet-4-6"

# --- Telegram ---
TG_TOKEN = "123456:telegram-bot-token"
# Faqat shu Telegram ID'lar bot bilan gaplasha oladi (@userinfobot dan oling):
ALLOWED_USERS = [123456789]

# --- Ixtiyoriy ---
# ERPNext'da bitta kompaniya bo'lsa bo'sh qoldiring (avtomatik aniqlanadi):
COMPANY = ""
# "bugun/kecha/bu oy" qaysi vaqt mintaqasida hisoblanadi:
TIMEZONE = "Asia/Tashkent"
# Tayyor balans/pnl PDF fayllari turadigan papka (bo'sh => loyihadagi documents/):
DOCUMENTS_DIR = ""
# Har kuni shu vaqtda (TIMEZONE bo'yicha) kechagi kun uchun avtomatik hisobot yuboriladi.
# "02:00" => ertalab 2:00. Bo'sh "" qo'ysangiz — avtomatik hisobot o'chiq.
REPORT_TIME = "02:00"
